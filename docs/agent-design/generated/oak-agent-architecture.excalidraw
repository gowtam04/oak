      "index": "aT",
      "roundness": null,
      "seed": 101147,
      "version": 1,
      "versionNonce": 201643,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1760000000000,
      "link": null,
      "locked": false,
      "text": "Resolve/search:\nresolve_entity, query_pokedex\n\nEntity facts:\nget_pokemon, get_move\nget_ability, get_type_matchups\nget_evolution_chain, get_item\nget_encounters\n\nMath:\ncompute_stat, estimate_damage\n\nTeams/account:\nlist_teams, get_team, save_team\n\nTrends: get_usage_stats\nFinal: submit_answer",
      "rawText": "Resolve/search:\nresolve_entity, query_pokedex\n\nEntity facts:\nget_pokemon, get_move\nget_ability, get_type_matchups\nget_evolution_chain, get_item\nget_encounters\n\nMath:\ncompute_stat, estimate_damage\n\nTeams/account:\nlist_teams, get_team, save_team\n\nTrends: get_usage_stats\nFinal: submit_answer",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Resolve/search:\nresolve_entity, query_pokedex\n\nEntity facts:\nget_pokemon, get_move\nget_ability, get_type_matchups\nget_evolution_chain, get_item\nget_encounters\n\nMath:\ncompute_stat, estimate_damage\n\nTeams/account:\nlist_teams, get_team, save_team\n\nTrends: get_usage_stats\nFinal: submit_answer",
      "autoResize": false,
      "lineHeight": 1.02
    },
