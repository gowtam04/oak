      "isDeleted": false,
      "boundElements": null,
      "updated": 1760000000000,
      "link": null,
      "locked": false,
      "text": "Tools return structured facts or structured errors.\nNo in-domain exceptions for:\nmisses, empty results, mode gates,\nor missing index data.\nThe model cites returned facts.",
      "rawText": "Tools return structured facts or structured errors.\nNo in-domain exceptions for:\nmisses, empty results, mode gates,\nor missing index data.\nThe model cites returned facts.",
      "fontSize": 17,
      "fontFamily": 5,
