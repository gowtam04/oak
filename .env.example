# Anthropic API key — REQUIRED. src/env.ts rejects startup if this is missing.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model id for the Pokebot tool-loop (fixed by agent-design D2).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres connection string for the index + reference cache. Default matches
# the docker-compose `db` service; built/populated by `npm run ingest`.
DATABASE_URL=postgres://pokebot:pokebot@localhost:5432/pokebot

# PokeAPI base URL (the only place the ingest/cache layer calls upstream).
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Account creation (email + OTP auth) ------------------------------------

# Server secret for HMAC-hashing OTP codes. A dev default is used when unset, but
# PRODUCTION requires an explicit strong value — src/env.ts rejects the dev
# default when NODE_ENV=production. Generate one, e.g. `openssl rand -hex 32`.
AUTH_SECRET=dev-insecure-auth-secret-change-me

# Resend API key for sending OTP emails. ABSENT/empty ⇒ a console transport is
# used (the 6-digit code is logged, no real mail is sent — fine for local dev).
# Set a real key (re_...) to send actual email via Resend.
RESEND_API_KEY=

# From-address for OTP emails. The default onboarding@resend.dev ONLY delivers to
# your own Resend account email — for real multi-user delivery, verify a domain
# in Resend and set this to an address on it, e.g. "Pokebot <noreply@your.com>".
EMAIL_FROM=Pokebot <onboarding@resend.dev>
