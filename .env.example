# xAI Grok API key — REQUIRED. Grok 4.3 is the PRIMARY model; src/env.ts rejects
# startup if this is missing. The app is designed around Grok's native provider.
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1

# --- Active model (operator-controlled; there is NO in-app model picker) ------
# Which LLM answers every turn: grok-4.3 (default) | claude | gpt-5.5. Switch the
# model by changing this one secret (e.g. `fly secrets set ACTIVE_MODEL=claude`) —
# no rebuild. The chosen model's provider key (below) must be configured, or the
# request returns a clean 503. An unknown value fails fast at boot. Unset ⇒ grok-4.3.
ACTIVE_MODEL=grok-4.3

# --- Alternate model providers (needed only if ACTIVE_MODEL points at them) ---
# Grok (above) is the ONLY required provider; the app boots with just XAI_API_KEY.
# Set a key below to enable that model; keys are validated ON USE.
#
# Claude (used when ACTIVE_MODEL=claude):
ANTHROPIC_API_KEY=
# Model id used for Claude — claude-sonnet-4-6 is Claude Sonnet 4.6.
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenAI GPT-5.5 (used when ACTIVE_MODEL=gpt-5.5):
OPENAI_API_KEY=
# OPENAI_BASE_URL=                       # optional; defaults to the OpenAI SDK base

# Postgres connection string for the index + reference cache. Default matches
# the docker-compose `db` service; built/populated by `npm run ingest`.
DATABASE_URL=postgres://oak:oak@localhost:5432/oak

# PokeAPI base URL (the only place the ingest/cache layer calls upstream).
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Account creation (email + OTP auth) ------------------------------------

# Server secret for HMAC-hashing OTP codes. A dev default is used when unset, but
# PRODUCTION requires an explicit strong value — src/env.ts rejects the dev
# default when NODE_ENV=production. Generate one, e.g. `openssl rand -hex 32`.
AUTH_SECRET=dev-insecure-auth-secret-change-me

# Resend API key for sending OTP emails. ABSENT/empty ⇒ a console transport is
# used (the 6-digit code is logged, no real mail is sent — fine for local dev).
# Set a real key (re_...) to send actual email via Resend.
RESEND_API_KEY=

# From-address for OTP emails. The default onboarding@resend.dev ONLY delivers to
# your own Resend account email — for real multi-user delivery, verify a domain
# in Resend and set this to an address on it, e.g. "Oak <noreply@your.com>".
EMAIL_FROM=Oak <onboarding@resend.dev>
