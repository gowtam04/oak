{
  "name": "oak",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test_one": "vitest run",
    "test:node": "vitest run --project node",
    "test:components": "vitest run --project jsdom",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/data/migrate.ts",
    "ingest": "tsx src/ingest/run.ts",
    "fetch:encounters": "tsx scripts/fetch-pokeapi-encounters.ts",
    "eval": "tsx eval/run.ts",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:migrate": "docker compose -f docker-compose.dev.yml run --rm web npm run db:migrate",
    "docker:ingest": "docker compose -f docker-compose.dev.yml run --rm web npm run ingest",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f web",
    "docker:psql": "docker compose -f docker-compose.dev.yml exec db psql -U oak -d oak",
    "docker:sh": "docker compose -f docker-compose.dev.yml exec web bash"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.106.0",
    "@pkmn/data": "^0.10.11",
    "@pkmn/dex": "^0.10.11",
    "@pkmn/mods": "^0.10.11",
    "@pkmn/sets": "^5.2.0",
    "drizzle-orm": "0.45.2",
    "fuse.js": "7.4.2",
    "next": "15.5.19",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "server-only": "0.0.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "7.18.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  }
}
